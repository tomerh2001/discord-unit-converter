# Copy to `.env` next to compose.yml on your server and fill in the token.
# (CLIENT_ID below is the app's public Application ID — already correct.)

DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=1521143093947273316

# Leave empty — commands are registered globally.
GUILD_ID=

# Defaults are fine; override only if you want to.
DATA_DIR=./data
DEFAULT_PRECISION=2
AUTO_DETECT_DEFAULT=true
