# ── Required ──────────────────────────────────────────────────────────────
# Your bot token from the Discord Developer Portal (Bot tab → Reset Token).
DISCORD_TOKEN=your-bot-token-here

# Your application's Client ID (Developer Portal → General Information → Application ID).
CLIENT_ID=your-application-id-here

# ── Optional ──────────────────────────────────────────────────────────────
# If set, slash commands are registered to this single guild (server) instead
# of globally. Guild commands update instantly — great for development.
# Leave blank to register commands globally (can take up to ~1 hour to appear).
GUILD_ID=

# Where the SQLite database lives. Defaults to ./data/units.db
DATA_DIR=./data

# Number of significant-ish decimal places used when displaying conversions.
DEFAULT_PRECISION=2

# Set to "false" to make auto-detection opt-in per server (default on).
AUTO_DETECT_DEFAULT=true
